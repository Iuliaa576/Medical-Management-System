<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox spacing="20" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AppointmentsGUIController">
    <children>
        <ListView fx:id="appointmentListView" minWidth="450" VBox.vgrow="ALWAYS"/>
        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints prefWidth="150"/>
                <ColumnConstraints prefWidth="200"/>
                <ColumnConstraints prefWidth="120"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="30"/>
                <RowConstraints minHeight="30"/>
                <RowConstraints minHeight="30"/>
                <RowConstraints minHeight="30"/>
                <RowConstraints minHeight="60"/>
                <RowConstraints minHeight="30"/>
                <RowConstraints minHeight="30"/>
                <RowConstraints minHeight="40"/>
                <RowConstraints minHeight="40.0" prefHeight="40.0"/>
            </rowConstraints>
            <Label text="ID:" GridPane.rowIndex="0"/>
            <TextField fx:id="appointmentIdField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <Button fx:id="findButton" text="Find by ID" onAction="#handleFindById" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <Label text="Patient ID:" GridPane.rowIndex="1"/>
            <TextField fx:id="patientIdField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <Label text="Date &amp; Time (yyyy-MM-dd HH:mm)" GridPane.rowIndex="2"/>
            <TextField fx:id="dateTimeField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            <HBox spacing="10" alignment="CENTER" GridPane.columnSpan="3" GridPane.rowIndex="4">
                <children>
                    <Button fx:id="addButton" text="Add" onAction="#handleAdd"/>
                    <Button fx:id="updateButton" text="Update" onAction="#handleUpdate"/>
                    <Button fx:id="deleteButton" text="Delete" onAction="#handleDelete"/>
                </children>
            </HBox>
            <Label text="Filter by patient ID" GridPane.rowIndex="5"/>
            <TextField fx:id="filterPatientIdField" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
            <Button fx:id="filterPatientButton" text="Filter" onAction="#handleFilterByPatient" GridPane.columnIndex="2" GridPane.rowIndex="5"/>
            <Label text="Filter by date (yyyy-MM-dd)" GridPane.rowIndex="6"/>
            <TextField fx:id="filterDateField" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
            <Button fx:id="filterDateButton" text="Filter" onAction="#handleFilterByDate" GridPane.columnIndex="2" GridPane.rowIndex="6"/>
            <Button fx:id="resetButton" text="RESET" onAction="#handleReset" GridPane.rowIndex="7"/>
            <HBox spacing="15"
                  GridPane.columnSpan="3"
                  GridPane.rowIndex="9"
                  GridPane.halignment="CENTER">
                <children>
                    <Button text="UNDO"
                            prefWidth="120"
                            onAction="#handleUndo"/>
                    <Button text="REDO"
                            prefWidth="120"
                            onAction="#handleRedo"/>
                </children>
            </HBox>

        </GridPane>
    </children>
</HBox>
