<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.BulkUpdateDemoController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Bulk Update Demo (Multithreading)"
           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Threads:" GridPane.rowIndex="0"/>
        <TextField fx:id="countField" text="100000" GridPane.columnIndex="1"/>

        <TextField fx:id="threadsField" text="8" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Generate" onAction="#handleGenerate"/>
        <Button text="Run with Threads" onAction="#handleThreads"/>
        <Button text="Run with ExecutorService" onAction="#handleExecutor"/>
    </HBox>

    <Label text="Generated Patients (virtualized list, can handle 100,000)"/>

    <ListView fx:id="patientsListView" prefHeight="220"/>

    <TextArea fx:id="outputArea" prefHeight="200" editable="false"/>
</VBox>
