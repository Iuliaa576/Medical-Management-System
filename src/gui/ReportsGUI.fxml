<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="20" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ReportsGUIController">
    <children>
        <VBox spacing="10" prefWidth="300">
            <Button text="Report 1: Patients + Appointment Count" onAction="#handleReport1"/>
            <Button text="Report 2: Busiest Day" onAction="#handleReport2"/>
            <Button text="Report 3: Appointments by Weekday" onAction="#handleReport3"/>
            <Button text="Report 4: Overlapping Appointments" onAction="#handleReport4"/>
            <Button text="Report 5: Patients by Email Domain" onAction="#handleReport5"/>
            <Button text="RESET" onAction="#handleReset"/>
        </VBox>
        <ListView fx:id="reportListView" prefWidth="700"/>
    </children>
</HBox>
